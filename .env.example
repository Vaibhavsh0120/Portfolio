```env
# =============================================================================
# Mail / OTP
# =============================================================================

# Gmail address used to send contact form mail and admin OTP codes
# Example: yourname@gmail.com
EMAIL_USER="your-email@gmail.com"

# Gmail App Password (16 characters generated from Google Account)
# Example: abcd efgh ijkl mnop
EMAIL_APP_PASSWORD="your-gmail-app-password"

# Random secret used to sign OTP/session state
# Generate: openssl rand -base64 32
ADMIN_SESSION_SECRET="your-random-secret"


# =============================================================================
# Firebase Client (Project Settings > General > Your apps > SDK setup)
# =============================================================================

# Example: AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"

# Example: my-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"

# Example: my-project
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"

# Example: my-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"

# Example: 123456789012
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"

# Example: 1:123456789012:web:abcdef1234567890abcdef
NEXT_PUBLIC_FIREBASE_APP_ID="your-firebase-app-id"

# Example: G-ABC123XYZ9
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# Comma-separated list of admin emails
# Example: admin@gmail.com,user@gmail.com
NEXT_PUBLIC_ADMIN_EMAILS="admin@example.com"


# =============================================================================
# Firebase Admin (Project Settings > Service Accounts)
# =============================================================================

# Example: my-project-id
FIREBASE_ADMIN_PROJECT_ID="your-project-id"

# Example:
# firebase-adminsdk-abc12@my-project.iam.gserviceaccount.com
FIREBASE_ADMIN_CLIENT_EMAIL="your-service-account-email"

# Copy the ENTIRE private key from the downloaded service account JSON.
# Keep newline escapes as \n.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Optional local path to the downloaded service account JSON
# Example: ./firebase-adminsdk.json
FIREBASE_ADMIN_SERVICE_ACCOUNT_PATH="./firebase-adminsdk.json"


# =============================================================================
# Cloudinary
# =============================================================================

# Dashboard → Product Environment Credentials
# Example: my-cloud-name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Example: 123456789012345
CLOUDINARY_API_KEY="your-cloudinary-api-key"

# Example: AbCdEfGhIjKlMnOpQrStUvWxYz123456
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Format:
# cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Example:
# cloudinary://123456789012345:AbCdEfGhIjKlMnOpQrStUvWxYz123456@my-cloud-name
CLOUDINARY_URL="cloudinary://your-api-key:your-api-secret@your-cloud-name"
```
