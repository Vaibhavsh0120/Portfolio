# Mail / OTP
# Gmail address used to send contact form mail and admin OTP codes
EMAIL_USER=""
# Gmail App Password for the account above
EMAIL_APP_PASSWORD=""
# Random secret used to sign OTP/session state on the server
ADMIN_SESSION_SECRET=""

# Firebase client
# Firebase Web App config from Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
# Comma-separated admin emails allowed into /admin
NEXT_PUBLIC_ADMIN_EMAILS=""

# Firebase admin
# Preferred for deployment: Firebase service account fields from Project Settings > Service Accounts
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
# Keep newline escapes as \n when storing this in env vars
FIREBASE_ADMIN_PRIVATE_KEY=""
# Optional local fallback path to a firebase-adminsdk JSON file
FIREBASE_ADMIN_SERVICE_ACCOUNT_PATH=""

# Cloudinary
# Public cloud name from your Cloudinary dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Server-side Cloudinary API credentials
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Full Cloudinary URL, format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=""
